{
  "name": "wikiwire",
  "version": "0.3.0",
  "description": "A GitHub Action which syncs Git modules/templates to MediaWiki",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --format=cjs --minify --legal-comments=none",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/obbywiki/wikiwire.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@iarna/toml": "^2.2.5",
    "ignore": "^7.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/node": "^22.19.3",
    "esbuild": "^0.25.12",
    "typescript": "^6.0.2"
  }
}
